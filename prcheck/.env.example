# Anthropic API key (required for PR description generation)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# HuggingFace API token (optional — needed for private commit-classifier models)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Commit classifier model ID on HuggingFace Hub
# Change this to your published model
PRCHECK_MODEL=your-username/commit-classifier
